{
  "name": "coinpulse-tests-cypress",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone Cypress end-to-end suite for CoinPulse (UI and API). Runs against a locally running frontend and backend and shares no dependencies with the frontend project.",
  "type": "module",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test:e2e": "cypress run",
    "test:smoke": "cypress run --spec \"cypress/e2e/smoke/**/*.cy.ts\"",
    "test:dashboard": "cypress run --spec \"cypress/e2e/dashboard/**/*.cy.ts\"",
    "test:markets": "cypress run --spec \"cypress/e2e/markets/**/*.cy.ts\"",
    "test:trade": "cypress run --spec \"cypress/e2e/trade/**/*.cy.ts\"",
    "test:coin-form": "cypress run --spec \"cypress/e2e/coin-form/**/*.cy.ts\"",
    "test:api-explorer": "cypress run --spec \"cypress/e2e/api-explorer/**/*.cy.ts\"",
    "test:files": "cypress run --spec \"cypress/e2e/files/**/*.cy.ts\"",
    "test:dynamic": "cypress run --spec \"cypress/e2e/dynamic/**/*.cy.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run format:check && npm run lint && npm run typecheck"
  },
  "devDependencies": {
    "@cypress/grep": "^6.0.0",
    "@eslint/js": "^9.17.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@types/node": "^22.10.0",
    "cypress": "15.14.1",
    "cypress-mochawesome-reporter": "^4.0.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-chai-friendly": "^1.0.1",
    "eslint-plugin-mocha": "^11.0.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0"
  }
}
